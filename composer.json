{
    "name": "qutlet/qutlet-core",
    "description": "Qutlet Core — model danych (pola ACF, CPT, glue do WooCommerce).",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "php-stubs/acf-pro-stubs": "^6.0",
        "php-stubs/woocommerce-stubs": "^10.9",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^9.6",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Qutlet\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Qutlet\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "test": "phpunit"
    }
}
