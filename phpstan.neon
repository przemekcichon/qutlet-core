# PHPStan dla qutlet-core (D-G2). Poziom startowy 5 — podnosimy osobnym punktem,
# gdy będzie realny kod do analizy. Stuby WordPressa dostarcza rozszerzenie
# szepeviktor/phpstan-wordpress (ładowane poniżej).
includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - qutlet-core.php
        - src/
    excludePaths:
        - vendor/
    # Stuby ACF PRO i WooCommerce — twarde zależności core (D-G5), nieobecne w
    # środowisku analizy PHPStan. Dają realne typowanie (`acf_*`, `WC_Product`,
    # `wc_format_decimal`, `woocommerce_wp_text_input`) zamiast ignorowania błędów.
    # Materializacja: `composer update php-stubs/*` (vendor/ jest w .gitignore).
    scanFiles:
        - vendor/php-stubs/acf-pro-stubs/acf-pro-stubs.php
        - vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
